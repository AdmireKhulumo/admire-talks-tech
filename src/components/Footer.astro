---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Admire Khulumo. All rights reserved.</p>
	<div class="social-links">
		<a href="https://www.linkedin.com/in/admire-khulumo/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
		<a href="https://github.com/AdmireKhulumo" target="_blank" rel="noopener noreferrer">GitHub</a>
	</div>
</footer>
<style>
	footer {
		padding: 2rem 1rem 4rem;
		background-color: var(--color-parchment);
		border-top: 1px solid var(--color-border-cream);
		color: var(--color-olive-gray);
		text-align: center;
	}
	footer p {
		margin: 0;
		font-size: 0.875rem;
	}
	.social-links {
		margin-top: 0.75rem;
		display: flex;
		justify-content: center;
		gap: 1.25rem;
	}
	.social-links a {
		font-size: 0.875rem;
		color: var(--color-olive-gray);
		text-decoration: none;
	}
	.social-links a:hover {
		text-decoration: underline;
	}
</style>
